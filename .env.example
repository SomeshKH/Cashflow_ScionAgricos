# ─── ScionAgricos Dashboard – Environment Variables ──────────────────────────
#
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed.
#
# In Vercel: paste these into Project → Settings → Environment Variables

# FastAPI backend base URL  (leave blank to use the Vite proxy / Vercel rewrite)
# VITE_API_BASE_URL=http://3.27.150.43:8000/api

# API Key sent as X-API-Key header on every request
VITE_API_KEY=your_api_key_here
