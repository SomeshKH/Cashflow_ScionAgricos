# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT  (.env.local  — never commit this file)
# ─────────────────────────────────────────────────────────────────────────────

# Points the React app at the Vercel proxy route.
# In local dev the Vite dev-server proxy forwards /api/proxy/* → localhost:8000
VITE_API_BASE_URL=/api/proxy

# ─────────────────────────────────────────────────────────────────────────────
# VERCEL PRODUCTION  (set these in Vercel Dashboard → Settings → Environment Variables)
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of your AWS API Gateway  (no trailing slash)
AWS_API_BASE_URL=https://ynz20suhb8.execute-api.ap-southeast-2.amazonaws.com/prod/api/v1

# Secret API key — server-side only, NEVER prefix with VITE_
AWS_BACKEND_API_KEY=your-aws-api-key-here

# Also set this in Vercel so the built frontend calls the proxy:
VITE_API_BASE_URL=/api/proxy
